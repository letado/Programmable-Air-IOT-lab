  {
    "id": "pa_v6_decode",
    "type": "function",
    "z": "pa_v6_tab",
    "name": "PA_DECODE",
    "func": "let d = null;\n\nif (Array.isArray(msg.payload)) {\n    d = msg.payload;\n} else if (msg.payload && Array.isArray(msg.payload.data)) {\n    d = msg.payload.data;\n} else if (msg.payload && Array.isArray(msg.payload.payload)) {\n    d = msg.payload.payload;\n}\n\nif (!d || d.length < 13) {\n    node.warn('Decode failed or payload too short');\n    return null;\n}\n\nconst pa = {\n    PV: Number(d[0]),\n    DIFF: Number(d[1]),\n    STATE: Number(d[2]),\n    ALARM: Number(d[3]),\n    SRC: Number(d[4]),\n    P1: Number(d[5]),\n    P2: Number(d[6]),\n    VL1: Number(d[7]),\n    VL2: Number(d[8]),\n    VL3: Number(d[9]),\n    VR1: Number(d[10]),\n    VR2: Number(d[11]),\n    VR3: Number(d[12])\n};\n\nglobal.set('pa', pa);\n\nreturn [\n  {payload: pa.PV},\n  {payload: pa.DIFF},\n  {payload: pa.STATE},\n  {payload: pa.ALARM},\n  {payload: pa.SRC},\n  {payload: pa.P1},\n  {payload: pa.P2},\n  {payload: pa.VL1},\n  {payload: pa.VL2},\n  {payload: pa.VL3},\n  {payload: pa.VR1},\n  {payload: pa.VR2},\n  {payload: pa.VR3}\n];",
    "outputs": 13,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 400,
    "y": 120,
    "wires": [
      [
        "pa_v6_pv_gauge",
        "pa_v6_pv_text",
        "pa_v6_pv_chart",
        "pa_v6_pv_debug"
      ],
      [
        "pa_v6_diff_text",
        "pa_v6_diff_chart"
      ],
