  {
    "id": "pa_v6_overview_fn",
    "type": "function",
    "z": "pa_v6_tab",
    "name": "Overview Banner",
    "func": "const pa = global.get('pa') || {};\nconst state = pa.STATE;\nconst alarm = pa.ALARM;\n\nif (alarm === 1) {\n  msg.payload = 'ALARM';\n} else if (state === 0) {\n  msg.payload = 'IDLE';\n} else if (state === 1) {\n  msg.payload = 'CONTRACTING';\n} else if (state === 2) {\n  msg.payload = 'EXPANDING';\n} else if (state === 3) {\n  msg.payload = 'LIMIT_REACHED';\n} else {\n  msg.payload = 'UNKNOWN';\n}\nreturn msg;",
    "outputs": 1,
    "noerr": 0,
    "x": 640,
    "y": 120,
    "wires": [
      [
        "pa_v6_overview_text"
      ]
    ]
  },
