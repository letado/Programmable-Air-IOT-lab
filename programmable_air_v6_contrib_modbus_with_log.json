    "type": "function",
    "z": "pa_v6_tab",
    "name": "Alarm Log Builder",
    "func": "msg.source = 'SCADA';\nmsg.log_type = 'ALARM';\nmsg.fc = 'FC3';\nmsg.address = '3';\nmsg.log_value = msg.payload;\nmsg.log_status = (msg.payload === 'HIGH_PRESSURE') ? 'ALERT' : 'OK';\nmsg.log_message = 'Alarm state changed';\nreturn msg;",
