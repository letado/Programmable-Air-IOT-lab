  {
    "id": "pa_v6_write_result_log_fn",
    "type": "function",
    "z": "pa_v6_tab",
    "name": "Write Result Log",
    "func": "msg.source = 'SCADA';\nmsg.log_type = 'WRITE';\nmsg.fc = 'FC5';\nmsg.address = (msg.payload && msg.payload.address !== undefined) ? String(msg.payload.address) : '';\nmsg.log_value = (msg.payload && msg.payload.value !== undefined) ? String(msg.payload.value) : '';\nmsg.log_status = 'ACK';\nmsg.log_message = 'Command write acknowledged';\nreturn msg;",
    "outputs": 1,
    "noerr": 0,
    "x": 900,
    "y": 640,
    "wires": [
      [
        "pa_v6_log_formatter"
      ]
    ]
  },
  {
    "id": "pa_v6_log_formatter",
    "type": "function",
    "z": "pa_v6_tab",
    "name": "Log Formatter",
    "func": "let logs = flow.get('modbus_logs') || [];\nfunction nowTime() {\n    const d = new Date();\n    return d.toLocaleTimeString();\n}\nconst entry = {\n    time: nowTime(),\n    source: msg.source || 'SCADA',\n    type: msg.log_type || 'INFO',\n    fc: msg.fc || '',\n    address: msg.address || '',\n    value: msg.log_value !== undefined ? String(msg.log_value) : '',\n    status: msg.log_status || 'OK',\n    message: msg.log_message || ''\n};\nlogs.unshift(entry);\nlogs = logs.slice(0, 150);\nflow.set('modbus_logs', logs);\nmsg.payload = logs;\nreturn msg;",
    "outputs": 1,
    "noerr": 0,
    "x": 1160,
    "y": 520,
    "wires": [
      [
        "pa_v6_modbus_log_template"
      ]
    ]
  },
  {
    "id": "pa_v6_modbus_log_template",
